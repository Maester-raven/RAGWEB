# Vite 代理已配置，留空即可（请求会由开发服务器转发到后端）
# 生产环境部署时改为实际后端地址，例如 http://your-server:6006
VITE_API_BASE_URL=

# /api/chat 数据源开关：
# true  -> 走独立 Python 后端（VITE_CHAT_BACKEND_URL）
# false -> 走 Vite 内置中间件（vite-plugin-chat-api.ts）
VITE_USE_PYTHON_CHAT_BACKEND=true

# 当 VITE_USE_PYTHON_CHAT_BACKEND=true 时生效
VITE_CHAT_BACKEND_URL=http://localhost:8000

# 数据库配置（仅服务端使用，不会暴露到浏览器）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=ragweb_chat
